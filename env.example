# Copy to `.env.local` and fill values. Never commit real secrets.

# Supabase (يُستخدم أيضاً في next.config لـ images.remotePatterns عند التحسين)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional (used for auth email redirect in registration)
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=

# Cloudflare Turnstile (register page captcha)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Contact form email (Resend)
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
